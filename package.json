{
  "name": "lol-haidou-mvp",
  "version": "0.5.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "helper": "node helper/server.mjs",
    "helper:exe": "node scripts/build-helper-exe.mjs",
    "helper:installer": "npm run helper:exe && node scripts/build-helper-installer.mjs",
    "build": "vinext build",
    "export:pages": "node scripts/export-pages.mjs",
    "start": "vinext start",
    "db:generate": "drizzle-kit generate",
    "test": "npm run build && node --test tests/rendered-html.test.mjs tests/start-script.test.mjs tests/helper-normalize.test.mjs tests/helper-server.test.mjs tests/helper-sgp.test.mjs tests/helper-installer.test.mjs tests/static-export.test.mjs tests/role-scoring.test.mjs tests/player-summary.test.mjs tests/match-commentary.test.mjs tests/network-rating.test.mjs tests/rating-graph.test.mjs tests/calibration-core.test.mjs tests/calibration-governance.test.mjs tests/service-operations.test.mjs tests/import-replay.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern pages-dist --ignore-pattern .next --ignore-pattern .wrangler --ignore-pattern helper-dist --ignore-pattern release"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postject": "^1.0.0-alpha.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
